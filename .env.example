# ============================================================
# Adhara Engine - Environment Variables
# ============================================================
# Created by: make init (copies this file to .env with auto-generated secrets)
# Manual setup: cp .env.example .env && edit values below
#
# All variables below must be uncommented (not prefixed with #).
# Docker Compose evaluates all service configs at startup, even
# for inactive profiles, so every referenced variable needs a value.

# ── Host ─────────────────────────────────────────────────────
# The hostname where Adhara Engine is accessible.
# Use "localhost" for local dev, or your domain for production.
# ADHARA_HOST=localhost

# ── Core ─────────────────────────────────────────────────────
# Secret key for signing tokens and session data.
# Auto-generated by `make init`. For manual setup, generate with:
#   openssl rand -base64 32
ENGINE_SECRET_KEY=change-me-to-a-random-string

# ── PostgreSQL ───────────────────────────────────────────────
# Password for the 'engine' database user.
POSTGRES_PASSWORD=engine

# ── MinIO / Object Storage ──────────────────────────────────
# Credentials for the built-in S3-compatible storage.
MINIO_ACCESS_KEY=engine
MINIO_SECRET_KEY=engine-secret

# ── Docker Socket ────────────────────────────────────────────
# Path to the Docker socket on your host machine.
# Default works for Docker Desktop and OrbStack.
# Colima:  /Users/<you>/.colima/default/docker.sock
# Podman:  /run/user/1000/podman/podman.sock
DOCKER_HOST_SOCKET=/var/run/docker.sock

# ── Port Pool ────────────────────────────────────────────────
# Range of host ports allocated to deployed sites.
# Each site gets one port from this pool.
# ENGINE_PORT_RANGE_START=4001
# ENGINE_PORT_RANGE_END=5000

# ══════════════════════════════════════════════════════════════
# Profile-specific variables
# ══════════════════════════════════════════════════════════════
# These have sensible defaults and work out of the box.
# Only change them if you know what you're doing.

# ── Zitadel (profile: zitadel) ──────────────────────────────
# Only used with `--profile zitadel`. Safe to leave as defaults.
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_DB_PASSWORD=zitadel

# ── OIDC / SSO (profile: auth or zitadel) ───────────────────
# Override these to use an external OIDC provider instead of
# the built-in Logto or Zitadel.
# OIDC_INTERNAL_URL=http://logto:3001
# OIDC_ISSUER=http://localhost:3001
# OIDC_JWKS_PATH=/oidc/jwks
# OIDC_USERINFO_PATH=/oidc/me
# OIDC_CLIENT_ID=

# ── Traefik / SSL ────────────────────────────────────────────
# Email for Let's Encrypt certificate registration (production only).
# ACME_EMAIL=admin@example.com

# ── Grafana (profile: observability) ────────────────────────
# Admin password for the Grafana dashboard.
GRAFANA_PASSWORD=admin

# ── API Token ────────────────────────────────────────────────
# Auto-populated by `make token`. Do not set manually.
# ADHARA_ENGINE_TOKEN=
